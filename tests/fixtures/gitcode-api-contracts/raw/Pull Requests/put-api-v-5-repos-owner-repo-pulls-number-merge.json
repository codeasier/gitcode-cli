      "name": "access_token",
      "type": "string",
      "required": true,
      "description": "用户授权码"
    }
  ],
  "requestBodyFields": [
    {
      "name": "merge_method",
      "type": "string",
      "required": false,
      "description": "可选。合并PR的方法，merge（合并所有提交）、squash（扁平化分支合并）和rebase（变基并合并）。默认为merge。"
